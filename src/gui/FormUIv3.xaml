<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinTuner" Height="820" Width="940" MinHeight="620" MinWidth="780"
    WindowStartupLocation="CenterScreen"
    UseLayoutRounding="True"
    FontFamily="Segoe UI"
    Background="#14161B"
    TextOptions.TextFormattingMode="Display">

    <!-- ===================================================================
         THEME — "Instrument panel": graphite surfaces + a single amber
         signal accent. Minimal hairlines, flat fills, monospace consoles.
         All controls are re-templated so nothing falls back to the stock
         light-gray Windows chrome.
    ==================================================================== -->
    <Window.Resources>

        <!-- ===== Palette ===== -->
        <SolidColorBrush x:Key="Bg.Window"     Color="#14161B" />
        <SolidColorBrush x:Key="Bg.Panel"      Color="#1B1E25" />
        <SolidColorBrush x:Key="Bg.Input"      Color="#23272F" />
        <SolidColorBrush x:Key="Bg.InputHover" Color="#2B303A" />
        <SolidColorBrush x:Key="Border.Hair"   Color="#2E333D" />
        <SolidColorBrush x:Key="Border.Strong" Color="#3B414D" />
        <SolidColorBrush x:Key="Text.Primary"  Color="#E7E9ED" />
        <SolidColorBrush x:Key="Text.Muted"    Color="#969CA8" />
        <SolidColorBrush x:Key="Text.Faint"    Color="#6F7682" />
        <SolidColorBrush x:Key="Accent"        Color="#E3A436" />
        <SolidColorBrush x:Key="Accent.Hover"  Color="#F2B753" />
        <SolidColorBrush x:Key="Danger"        Color="#DE5A4D" />
        <SolidColorBrush x:Key="Console.Bg"    Color="#0F1115" />
        <SolidColorBrush x:Key="Console.Fg"    Color="#D6DAE1" />

        <!-- ===== Typography helpers ===== -->
        <Style x:Key="Heading" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize"   Value="15" />
            <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
        </Style>

        <Style x:Key="SubHeading" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Text.Muted}" />
        </Style>

        <!-- ===== TextBlock (default) ===== -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize"   Value="12" />
        </Style>

        <!-- ===== Label ===== -->
        <Style TargetType="Label">
            <Setter Property="Foreground"         Value="{StaticResource Text.Muted}" />
            <Setter Property="FontFamily"         Value="Segoe UI" />
            <Setter Property="FontSize"           Value="12" />
            <Setter Property="Padding"            Value="0,2" />
            <Setter Property="VerticalAlignment"  Value="Center" />
        </Style>

        <!-- ===== TextBox ===== -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource Bg.Input}" />
            <Setter Property="Foreground"      Value="{StaticResource Text.Primary}" />
            <Setter Property="CaretBrush"      Value="{StaticResource Accent}" />
            <Setter Property="SelectionBrush"  Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush"     Value="{StaticResource Border.Strong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="6,6" />
            <Setter Property="MinHeight"       Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily"      Value="Segoe UI" />
            <Setter Property="FontSize"        Value="12" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== Button (flat base + variants) ===== -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"        Value="{StaticResource Text.Primary}" />
            <Setter Property="Background"         Value="{StaticResource Bg.Input}" />
            <Setter Property="BorderBrush"        Value="{StaticResource Border.Strong}" />
            <Setter Property="BorderThickness"    Value="1" />
            <Setter Property="FontFamily"         Value="Segoe UI" />
            <Setter Property="FontSize"           Value="12" />
            <Setter Property="Padding"            Value="12,5" />
            <Setter Property="Cursor"             Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{StaticResource Bg.InputHover}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Border.Hair}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- default Button = flat base -->
        <Style TargetType="Button" BasedOn="{StaticResource BtnBase}" />

        <!-- primary action = filled amber -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="{StaticResource Accent}" />
            <Setter Property="Foreground"  Value="#1A1306" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="FontFamily"  Value="Bahnschrift SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{StaticResource Accent.Hover}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Accent.Hover}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C98A26" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- destructive action = filled red -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="{StaticResource Danger}" />
            <Setter Property="Foreground"  Value="#FFF1EF" />
            <Setter Property="BorderBrush" Value="{StaticResource Danger}" />
            <Setter Property="FontFamily"  Value="Bahnschrift SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#EC6A5E" />
                    <Setter Property="BorderBrush" Value="#EC6A5E" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- app launcher tile (icon over label) — built in Prepare_QuickLaunch -->
        <Style x:Key="AppTile" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Width"   Value="78" />
            <Setter Property="Height"  Value="58" />
            <Setter Property="Margin"  Value="0,0,6,6" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <!-- ===== CheckBox ===== -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="box" Width="16" Height="16" VerticalAlignment="Center"
                                    Background="{StaticResource Bg.Input}"
                                    BorderBrush="{StaticResource Border.Strong}" BorderThickness="1">
                                <Path x:Name="check" Data="M3,8 L7,12 L13,4"
                                      Stroke="{StaticResource Accent}" StrokeThickness="2"
                                      Stretch="None" SnapsToDevicePixels="True" Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible" />
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ComboBox (full dark re-template, editable-aware) ===== -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding"    Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Bg.InputHover}" />
                                <Setter Property="Foreground" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground"      Value="{StaticResource Text.Primary}" />
            <Setter Property="Background"      Value="{StaticResource Bg.Input}" />
            <Setter Property="BorderBrush"     Value="{StaticResource Border.Strong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="6,6" />
            <Setter Property="FontFamily"      Value="Segoe UI" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="MinHeight"       Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="22" />
                            </Grid.ColumnDefinitions>

                            <!-- frame -->
                            <Border x:Name="bd" Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />

                            <!-- whole-surface toggle (with the arrow) -->
                            <ToggleButton Grid.ColumnSpan="2" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="22" />
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="1" Data="M0,0 L8,0 L4,5 Z"
                                                  Fill="{StaticResource Text.Muted}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- selected value (non-editable) -->
                            <ContentPresenter x:Name="contentSite" Grid.Column="0"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left" />

                            <!-- editable text region -->
                            <TextBox x:Name="PART_EditableTextBox" Grid.Column="0"
                                     Margin="{TemplateBinding Padding}" VerticalAlignment="Center"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="0" MinHeight="0"
                                     HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"
                                     Foreground="{StaticResource Text.Primary}"
                                     CaretBrush="{StaticResource Accent}"
                                     SelectionBrush="{StaticResource Accent}"
                                     Visibility="Hidden" Focusable="True" />

                            <!-- dropdown -->
                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="{StaticResource Bg.Input}"
                                        BorderBrush="{StaticResource Border.Strong}" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter SnapsToDevicePixels="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="contentSite" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ListBox ===== -->
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="{StaticResource Bg.Panel}" />
            <Setter Property="Foreground"      Value="{StaticResource Text.Primary}" />
            <Setter Property="BorderBrush"     Value="{StaticResource Border.Hair}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily"      Value="Segoe UI" />
            <Setter Property="FontSize"        Value="12" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding"    Value="8,5" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,1" BorderBrush="{StaticResource Border.Hair}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Bg.InputHover}" />
                                <Setter Property="Foreground" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Bg.Input}" />
                                <Setter Property="Foreground" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== TabControl / TabItem ===== -->
        <Style TargetType="TabControl">
            <Setter Property="Background"      Value="{StaticResource Bg.Panel}" />
            <Setter Property="BorderBrush"     Value="{StaticResource Border.Hair}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource Text.Muted}" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent" Padding="16,9" Margin="0,0,2,0"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Bg.Panel}" />
                                <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Bg.Panel}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                                <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== DataGrid ===== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="{StaticResource Bg.Panel}" />
            <Setter Property="Foreground"               Value="{StaticResource Text.Primary}" />
            <Setter Property="BorderBrush"              Value="{StaticResource Border.Hair}" />
            <Setter Property="BorderThickness"          Value="1" />
            <Setter Property="RowBackground"            Value="{StaticResource Bg.Panel}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource Bg.Input}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Border.Hair}" />
            <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource Border.Hair}" />
            <Setter Property="RowHeaderWidth"           Value="0" />
            <Setter Property="FontFamily"               Value="Segoe UI" />
            <Setter Property="FontSize"                 Value="12" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{StaticResource Bg.Window}" />
            <Setter Property="Foreground"      Value="{StaticResource Text.Muted}" />
            <Setter Property="FontFamily"      Value="Bahnschrift" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Padding"         Value="8,6" />
            <Setter Property="BorderBrush"     Value="{StaticResource Border.Hair}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground"  Value="{StaticResource Text.Primary}" />
            <Setter Property="Background"  Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding"     Value="6,3" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"  Value="{StaticResource Accent}" />
                    <Setter Property="Foreground"  Value="#1A1306" />
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== RichTextBox (activity log) ===== -->
        <Style TargetType="RichTextBox">
            <Setter Property="Background"      Value="{StaticResource Console.Bg}" />
            <Setter Property="Foreground"      Value="{StaticResource Console.Fg}" />
            <Setter Property="BorderBrush"     Value="{StaticResource Border.Hair}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="6" />
            <Setter Property="FontFamily"      Value="Cascadia Mono, Consolas" />
        </Style>

        <!-- ===== GridSplitter ===== -->
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{StaticResource Border.Hair}" />
        </Style>

        <!-- ===== Slim dark ScrollBar ===== -->
        <Style x:Key="SbThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource Border.Strong}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource Bg.Window}" />
            <Setter Property="Width"      Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SbThumb}" Margin="2,0" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width"  Value="Auto" />
                                <Setter Property="Height" Value="10" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0: header band -->
            <RowDefinition Height="Auto" />  <!-- 1: general info -->
            <RowDefinition Height="*" />     <!-- 2: feature tabs -->
            <RowDefinition Height="Auto" />  <!-- 3: log toolbar -->
            <RowDefinition Height="160" />   <!-- 4: activity log -->
        </Grid.RowDefinitions>

        <!-- ============ Header band — wordmark + accent block ============ -->
        <Border Grid.Row="0" Background="{StaticResource Bg.Panel}"
                BorderBrush="{StaticResource Border.Hair}" BorderThickness="0,0,0,1" Padding="16,11">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="6" Height="30" Background="{StaticResource Accent}" />
                <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="WINTUNER" FontFamily="Bahnschrift SemiBold"
                               FontSize="18" Foreground="{StaticResource Text.Primary}" />
                    <TextBlock Text="Windows system tuning utility" FontFamily="Bahnschrift"
                               FontSize="11" Foreground="{StaticResource Text.Muted}" Margin="0,1,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ============ General info (always visible, above the tabs) ============ -->
        <!-- Three columns: This machine | Common paths | Common apps -->
        <Grid Grid.Row="1" Margin="16,12,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- == This machine == -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Heading + session/elevation status on the same line -->
                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="This machine" Style="{StaticResource Heading}" VerticalAlignment="Center" />
                    <TextBox x:Name="txt_AdminStatus" IsReadOnly="True" BorderThickness="0"
                             Background="Transparent" VerticalAlignment="Center" Margin="14,0,0,0"
                             ToolTip="Whether this app is running with Administrator rights." />
                    <Button  x:Name="btn_Elevate" Content="Restart as administrator"
                             Style="{StaticResource PrimaryButton}"
                             Height="24" Padding="10,0" Margin="10,0,0,0" Visibility="Collapsed"
                             VerticalAlignment="Center"
                             ToolTip="Relaunches the app with a UAC prompt. Needed for HKLM / HKU registry writes." />
                </StackPanel>

                <Label   Grid.Row="1" Grid.Column="0" Content="User:" />
                <TextBox x:Name="txt_YourUserName" Grid.Row="1" Grid.Column="1"
                         IsReadOnly="True" Margin="6,2" />

                <Label   Grid.Row="2" Grid.Column="0" Content="Computer:" />
                <TextBox x:Name="txt_YourPcName" Grid.Row="2" Grid.Column="1"
                         IsReadOnly="True" Margin="6,2" />

                <Label   Grid.Row="3" Grid.Column="0" Content="IP address:" />
                <TextBox x:Name="txt_YourIP" Grid.Row="3" Grid.Column="1"
                         IsReadOnly="True" Margin="6,2" />

                <Label   Grid.Row="4" Grid.Column="0" Content="Network:" />
                <TextBox x:Name="txt_YourNetwork" Grid.Row="4" Grid.Column="1"
                         IsReadOnly="True" Margin="6,2" />

                <!-- == Local disks (sizes in GB; headers shortened to fit the column) == -->
                <DockPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,14,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Disks" Style="{StaticResource SubHeading}" VerticalAlignment="Center" />
                        <Button x:Name="btn_Disks_Refresh" Content="Refresh" Height="20" Padding="8,0"
                                Margin="10,0,0,0" VerticalAlignment="Center"
                                ToolTip="Re-read the local fixed drives and their used / total space." />
                    </StackPanel>
                    <DataGrid x:Name="dgr_Disks" MaxHeight="150"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" HorizontalScrollBarVisibility="Disabled"
                              ToolTip="Local fixed drives on this machine. Used / Total / Free are in GB.">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Drive" Binding="{Binding Drive}"   Width="52" />
                            <DataGridTextColumn Header="Label" Binding="{Binding Label}"   Width="*" MinWidth="70" />
                            <DataGridTextColumn Header="Used"  Binding="{Binding UsedGB}"  Width="48" />
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalGB}" Width="48" />
                            <DataGridTextColumn Header="Free"  Binding="{Binding FreeGB}"  Width="48" />
                            <DataGridTextColumn Header="%"     Binding="{Binding UsedPct}" Width="42" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Grid>

            <!-- == Common paths (single-click opens in Explorer) == -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Common paths" Style="{StaticResource Heading}"
                           Margin="0,0,0,12" />
                <ListBox x:Name="lst_QuickPaths" DisplayMemberPath="label"
                         ToolTip="Single-click to open the folder in Explorer." />
            </DockPanel>

            <!-- == Common apps (icon tiles; left-click launches, right-click runs as admin) == -->
            <!-- Tiles are built at startup by Prepare_QuickLaunch into pnl_QuickApps. -->
            <DockPanel Grid.Column="4">
                <TextBlock DockPanel.Dock="Top" Text="Common apps" Style="{StaticResource Heading}"
                           Margin="0,0,0,12" />
                <Border Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border.Hair}"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="8">
                        <WrapPanel x:Name="pnl_QuickApps" Orientation="Horizontal"
                                   ToolTip="Left-click a tile to launch. Right-click to run as administrator (UAC)." />
                    </ScrollViewer>
                </Border>
            </DockPanel>
        </Grid>

        <!-- ============ Feature tabs (grouped by category) ============ -->
        <TabControl x:Name="tbc_Main" Grid.Row="2" Margin="16,0,16,0" Padding="0">

            <!-- ===================== System Tweaks ===================== -->
            <TabItem x:Name="tab_System" ToolTip="System settings and tools">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F5A5;" FontFamily="Segoe UI Emoji" Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="System Tweaks" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <TabControl Margin="0" Padding="0" BorderThickness="0">
                    <!-- Windows Features -->
                    <TabItem x:Name="tab_WindowsFeatures" ToolTip="Enable or disable Windows optional features">
                        <TabItem.Header>
                            <TextBlock Text="Windows Features" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="200" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Category filter -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label   Grid.Column="0" Content="Category:" VerticalAlignment="Center" />
                                <ComboBox x:Name="cmb_WinFeat_Category" Grid.Column="1" Margin="6,0" VerticalAlignment="Center" />
                                <Button   x:Name="btn_WinFeat_Refresh" Grid.Column="2" Content="Refresh List" Width="100" Height="28" Margin="12,0,0,0" />
                                <TextBlock x:Name="lbl_WinFeat_Status" Grid.Column="3" Text="Ready" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Muted}" />
                            </Grid>

                            <!-- Features grid -->
                            <DataGrid x:Name="dgr_WinFeat_Features" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column" SelectionMode="Extended"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Select" Binding="{Binding Selected}" Width="50" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="2*" />
                                    <DataGridTextColumn Header="Internal Name" Binding="{Binding Name}" Width="2*" />
                                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="80" />
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Action buttons -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="btn_WinFeat_Enable" Content="Enable Selected"
                                        Style="{StaticResource PrimaryButton}" Width="130" Height="28" />
                                <Button x:Name="btn_WinFeat_Disable" Content="Disable Selected"
                                        Style="{StaticResource DangerButton}" Width="140" Height="28" Margin="8,0,0,0" />
                                <CheckBox x:Name="chk_WinFeat_NoRestart" Content="No restart" VerticalAlignment="Center" Margin="16,0,0,0"
                                          ToolTip="Suppress restart prompt (may not work for all features)" />
                                <TextBlock Text="Some features may require a system restart."
                                           VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Faint}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="{StaticResource Text.Faint}"
                                       Text="Enable or disable Windows optional features like WSL, Hyper-V, Sandbox, and more. Select features and click Enable or Disable." />
                        </Grid>
                    </TabItem>

                    <!-- System Fixes -->
                    <TabItem x:Name="tab_SystemFixes" ToolTip="Common system repair tools">
                        <TabItem.Header>
                            <TextBlock Text="System Fixes" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="100" />
                            </Grid.RowDefinitions>

                            <!-- System File Checker -->
                            <GroupBox Grid.Row="0" Header="System File Checker (SFC)" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Margin="8,8,8,12">
                                    <Button x:Name="btn_SysFix_SFC" Content="Run SFC Scan"
                                            Style="{StaticResource PrimaryButton}" Width="120" Height="28" />
                                    <TextBlock Text="Scans and repairs Windows system files. May require administrator privileges."
                                               VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource Text.Faint}" />
                                </StackPanel>
                            </GroupBox>

                            <!-- DISM Repair -->
                            <GroupBox Grid.Row="1" Header="DISM Repair" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Margin="8,8,8,12">
                                    <Button x:Name="btn_SysFix_DISM" Content="Run DISM Repair"
                                            Style="{StaticResource PrimaryButton}" Width="130" Height="28" />
                                    <TextBlock Text="Repairs the Windows image. Use if SFC fails to repair files."
                                               VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource Text.Faint}" />
                                </StackPanel>
                            </GroupBox>

                            <!-- Network Reset -->
                            <GroupBox Grid.Row="2" Header="Network Reset" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Margin="8,8,8,12">
                                    <Button x:Name="btn_SysFix_NetReset" Content="Reset Network"
                                            Style="{StaticResource DangerButton}" Width="120" Height="28" />
                                    <TextBlock Text="Resets network settings (flushes DNS, resets IP, Winsock). May disconnect from network."
                                               VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource Text.Faint}" />
                                </StackPanel>
                            </GroupBox>

                            <!-- Windows Update Reset -->
                            <GroupBox Grid.Row="3" Header="Windows Update Reset" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Margin="8,8,8,12">
                                    <Button x:Name="btn_SysFix_WUReset" Content="Reset Windows Update"
                                            Style="{StaticResource DangerButton}" Width="150" Height="28" />
                                    <Button x:Name="btn_SysFix_WUClear" Content="Clear Cache" Width="100" Height="28" Margin="8,0,0,0" />
                                    <TextBlock Text="Resets Windows Update components or clears the update cache."
                                               VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource Text.Faint}" />
                                </StackPanel>
                            </GroupBox>

                            <TextBlock Grid.Row="4" Margin="0,8,0,0" Foreground="{StaticResource Text.Faint}"
                                       Text="These tools can help fix common Windows issues. Some operations may require administrator privileges and may temporarily disconnect you from the network." />
                        </Grid>
                    </TabItem>

                    <!-- Performance -->
                    <TabItem x:Name="tab_Performance" ToolTip="Change Windows power plans">
                        <TabItem.Header>
                            <TextBlock Text="Performance" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="100" />
                            </Grid.RowDefinitions>

                            <!-- Current plan -->
                            <GroupBox Grid.Row="0" Header="Current Power Plan" Margin="0,0,0,12">
                                <Grid Margin="8,8,8,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Label   Grid.Column="0" Content="Active Plan:" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lbl_Perf_Current" Grid.Column="1" Text="Loading..." VerticalAlignment="Center" Margin="6,0" Foreground="{StaticResource Text.Muted}" />
                                </Grid>
                            </GroupBox>

                            <!-- Plan selection -->
                            <GroupBox Grid.Row="1" Header="Select Power Plan" Margin="0,0,0,12">
                                <Grid Margin="8,8,8,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label   Grid.Column="0" Content="Plan:" VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmb_Perf_Plan" Grid.Column="1" Margin="6,0" VerticalAlignment="Center" />
                                    <Button   x:Name="btn_Perf_Refresh" Grid.Column="2" Content="Refresh" Width="80" Height="28" Margin="12,0,0,0" />
                                </Grid>
                            </GroupBox>

                            <!-- Action buttons -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                                <Button x:Name="btn_Perf_Apply" Content="Apply Plan"
                                        Style="{StaticResource PrimaryButton}" Width="100" Height="28" />
                                <Button x:Name="btn_Perf_Ultimate" Content="Enable Ultimate Performance" Width="180" Height="28" Margin="8,0,0,0" />
                                <TextBlock x:Name="lbl_Perf_Status" Text="Ready" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Muted}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="{StaticResource Text.Faint}"
                                       Text="Change Windows power plans to optimize performance or power consumption. Ultimate Performance is hidden by default and provides maximum performance at the cost of higher power usage." />
                        </Grid>
                    </TabItem>

                    <!-- Windows Update -->
                    <TabItem x:Name="tab_WindowsUpdate" ToolTip="Control Windows Update settings">
                        <TabItem.Header>
                            <TextBlock Text="Windows Update" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="100" />
                            </Grid.RowDefinitions>

                            <!-- Service status -->
                            <GroupBox Grid.Row="0" Header="Windows Update Service" Margin="0,0,0,12">
                                <Grid Margin="8,8,8,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Label   Grid.Column="0" Content="Status:" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lbl_WU_Status" Grid.Column="1" Text="Loading..." VerticalAlignment="Center" Margin="6,0" Foreground="{StaticResource Text.Muted}" />
                                    <Label   Grid.Column="2" Content="Startup Type:" VerticalAlignment="Center" Margin="12,0,0,0" />
                                    <TextBlock x:Name="lbl_WU_Startup" Grid.Column="3" Text="Loading..." VerticalAlignment="Center" Margin="6,0" Foreground="{StaticResource Text.Muted}" />
                                    <Button   x:Name="btn_WU_Refresh" Grid.Column="4" Content="Refresh" Width="80" Height="28" Margin="12,0,0,0" />
                                </Grid>
                            </GroupBox>

                            <!-- Update mode -->
                            <GroupBox Grid.Row="1" Header="Update Mode" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" Margin="8,8,8,12">
                                    <Button x:Name="btn_WU_Manual" Content="Manual (Notify Only)"
                                            Style="{StaticResource PrimaryButton}" Width="150" Height="28" />
                                    <Button x:Name="btn_WU_Auto" Content="Automatic"
                                            Style="{StaticResource PrimaryButton}" Width="100" Height="28" Margin="8,0,0,0" />
                                    <Button x:Name="btn_WU_Disable" Content="Disable Updates"
                                            Style="{StaticResource DangerButton}" Width="130" Height="28" Margin="8,0,0,0" />
                                    <TextBlock Text="Changes may require administrator privileges."
                                               VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Faint}" />
                                </StackPanel>
                            </GroupBox>

                            <!-- Actions -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                                <Button x:Name="btn_WU_Check" Content="Check for Updates"
                                        Style="{StaticResource PrimaryButton}" Width="140" Height="28" />
                                <Button x:Name="btn_WU_OpenSettings" Content="Open Settings" Width="120" Height="28" Margin="8,0,0,0" />
                                <TextBlock x:Name="lbl_WU_ActionStatus" Text="Ready" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Muted}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="{StaticResource Text.Faint}"
                                       Text="Control Windows Update behavior. Manual mode notifies you of updates but doesn't download/install automatically. Automatic mode downloads and installs updates automatically. Disable stops Windows Update entirely." />
                        </Grid>
                    </TabItem>

                    <!-- Registry -->
                    <TabItem x:Name="tab_Registry" ToolTip="Apply preset registry tweaks">
                        <TabItem.Header>
                            <TextBlock Text="Registry" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="120" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Tweak picker -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label    Grid.Column="0" Content="Tweak:" VerticalAlignment="Center" />
                                <ComboBox x:Name="cmb_Reg_Tweak" Grid.Column="1" Margin="6,0" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Description -->
                            <TextBlock x:Name="lbl_Reg_Desc" Grid.Row="1" Margin="0,0,0,4"
                                       TextWrapping="Wrap" Foreground="{StaticResource Text.Muted}" Text="Pick a tweak to see what it does." />

                            <!-- Path -->
                            <Grid Grid.Row="2" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label   Grid.Column="0" Content="Key path:" VerticalAlignment="Center" />
                                <TextBox x:Name="txt_Reg_Path" Grid.Column="1" Margin="6,0" IsReadOnly="True"
                                         VerticalAlignment="Center" FontFamily="Cascadia Mono, Consolas" />
                            </Grid>

                            <!-- Entries -->
                            <DataGrid x:Name="dgr_Reg_Entries" Grid.Row="3"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Value name" Binding="{Binding Key}"      Width="2*" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Type"       Binding="{Binding Type}"     Width="80" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Current"    Binding="{Binding Current}"  Width="*"  IsReadOnly="True" />
                                    <DataGridTextColumn Header="New value"  Binding="{Binding NewValue}" Width="*"  IsReadOnly="False" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Actions -->
                            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="btn_Reg_GetValue" Content="Read current" Width="110" Height="28" />
                                <Button x:Name="btn_Reg_Apply"    Content="Apply tweak"
                                        Style="{StaticResource PrimaryButton}" Width="110" Height="28" Margin="8,0,0,0" />
                                <TextBlock x:Name="lbl_Reg_AdminWarn" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{StaticResource Danger}" />
                            </StackPanel>

                            <TextBlock Grid.Row="5" Margin="0,8,0,0" Foreground="{StaticResource Text.Faint}"
                                       Text="The 'New value' column is editable. HKLM / HKU keys need the app run as Administrator." />
                        </Grid>
                    </TabItem>

                    <!-- Local PS -->
                    <TabItem x:Name="tab_LocalPS" ToolTip="Run PowerShell on this machine">
                        <TabItem.Header>
                            <TextBlock Text="Local PS" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="5" />
                                <RowDefinition Height="*" MinHeight="120" />
                            </Grid.RowDefinitions>

                            <!-- Search + description picker -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label   Grid.Column="0" Content="Search:" VerticalAlignment="Center" />
                                <TextBox x:Name="cmb_LocalPS" Grid.Column="1" VerticalAlignment="Center"
                                         ToolTip="Type to filter the preset list" />
                                <Label   Grid.Column="2" Content="Preset:" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <ComboBox x:Name="cmb_LocalPS_Desc" Grid.Column="3" Margin="6,0,0,0"
                                          IsEditable="False" IsTextSearchEnabled="False" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Command editor -->
                            <Label   Grid.Row="1" Content="Command:" />
                            <TextBox x:Name="cmb_LocalPS_Command" Grid.Row="2"
                                     Height="90" AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas"
                                     ToolTip="Enter = run, Shift+Enter = newline" />

                            <!-- Run row -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8">
                                <Button x:Name="btn_Run_LocalPS" Content="Run command"
                                        Style="{StaticResource PrimaryButton}" Width="120" Height="28" />
                                <Button x:Name="btn_Clear_LocalPS" Content="Clear output" Width="110" Height="28" Margin="8,0,0,0" />
                                <TextBlock Text="Runs in this app's PowerShell session. Use $global: vars to keep values between commands."
                                           VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource Text.Faint}" />
                            </StackPanel>

                            <GridSplitter Grid.Row="4" Height="5" HorizontalAlignment="Stretch"
                                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" />

                            <!-- Output console -->
                            <TextBox x:Name="txt_cmdline_LocalPS" Grid.Row="5"
                                     AcceptsReturn="True" IsReadOnly="True" TextWrapping="NoWrap"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                     Background="{StaticResource Console.Bg}" Foreground="{StaticResource Console.Fg}" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- ===================== Network ===================== -->
            <TabItem x:Name="tab_Network" ToolTip="Network tools and diagnostics">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F30E;" FontFamily="Segoe UI Emoji" Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="Network" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <TabControl Margin="0" Padding="0" BorderThickness="0">
                    <!-- DNS Changer -->
                    <TabItem x:Name="tab_DNS" ToolTip="Change DNS settings for network adapters">
                        <TabItem.Header>
                            <TextBlock Text="DNS Changer" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="100" />
                            </Grid.RowDefinitions>

                            <!-- Network adapter selection -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label   Grid.Column="0" Content="Network Adapter:" VerticalAlignment="Center" />
                                <ComboBox x:Name="cmb_DNS_Adapter" Grid.Column="1" Margin="6,0" VerticalAlignment="Center" />
                                <Button   x:Name="btn_DNS_Refresh" Grid.Column="2" Content="Refresh" Width="80" Height="28" Margin="12,0,0,0" />
                            </Grid>

                            <!-- DNS provider selection -->
                            <GroupBox Grid.Row="1" Header="DNS Provider" Margin="0,0,0,12">
                                <Grid Margin="8,8,8,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Label   Grid.Column="0" Content="Select Provider:" VerticalAlignment="Center" />
                                    <ComboBox x:Name="cmb_DNS_Provider" Grid.Column="1" Margin="6,0" VerticalAlignment="Center" />
                                </Grid>
                            </GroupBox>

                            <!-- Current DNS settings -->
                            <GroupBox Grid.Row="2" Header="Current DNS Settings" Margin="0,0,0,12">
                                <Grid Margin="8,8,8,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Label   Grid.Column="0" Content="Primary:" VerticalAlignment="Center" />
                                    <TextBlock x:Name="lbl_DNS_Primary" Grid.Column="1" Text="Not set" VerticalAlignment="Center" Margin="6,0" Foreground="{StaticResource Text.Muted}" />
                                    <Label   Grid.Column="2" Content="Secondary:" VerticalAlignment="Center" Margin="12,0,0,0" />
                                    <TextBlock x:Name="lbl_DNS_Secondary" Grid.Column="3" Text="Not set" VerticalAlignment="Center" Margin="6,0" Foreground="{StaticResource Text.Muted}" />
                                    <Label   Grid.Column="4" Content="Method:" VerticalAlignment="Center" Margin="12,0,0,0" />
                                    <TextBlock x:Name="lbl_DNS_Method" Grid.Column="5" Text="DHCP" VerticalAlignment="Center" Margin="6,0" Foreground="{StaticResource Text.Muted}" />
                                </Grid>
                            </GroupBox>

                            <!-- Action buttons -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                                <Button x:Name="btn_DNS_Apply" Content="Apply DNS"
                                        Style="{StaticResource PrimaryButton}" Width="100" Height="28" />
                                <Button x:Name="btn_DNS_Reset" Content="Reset to DHCP"
                                        Style="{StaticResource DangerButton}" Width="120" Height="28" Margin="8,0,0,0" />
                                <Button x:Name="btn_DNS_Flush" Content="Flush DNS Cache" Width="120" Height="28" Margin="8,0,0,0" />
                                <TextBlock x:Name="lbl_DNS_Status" Text="Ready" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Muted}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4" Margin="0,8,0,0" Foreground="{StaticResource Text.Faint}"
                                       Text="Change DNS settings for your network adapter. Select a provider and click Apply to set custom DNS servers, or Reset to DHCP to use automatic settings." />
                        </Grid>
                    </TabItem>

                    <!-- Network Diagnostics -->
                    <TabItem x:Name="tab_Diag" ToolTip="Local network diagnostics">
                        <TabItem.Header>
                            <TextBlock Text="Network Diagnostics" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="120" />
                            </Grid.RowDefinitions>

                            <!-- Target row -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <Label   Grid.Column="0" Content="Target host/IP:" VerticalAlignment="Center" />
                                <TextBox x:Name="txt_Diag_Target" Grid.Column="1" Margin="6,0" VerticalAlignment="Center"
                                         ToolTip="Needed for ping / tracert / nslookup. Not needed for ipconfig." />
                                <Label   Grid.Column="2" Content="Ping count:" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <TextBox x:Name="txt_Diag_PingCount" Grid.Column="3" Margin="6,0" Text="4" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Checks row -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                <CheckBox x:Name="chk_Diag_IPConfig" Content="ipconfig /all" VerticalAlignment="Center" />
                                <CheckBox x:Name="chk_Diag_NSLookup" Content="nslookup" VerticalAlignment="Center" Margin="14,0,0,0" />
                                <CheckBox x:Name="chk_Diag_Ping" Content="ping" IsChecked="True" VerticalAlignment="Center" Margin="14,0,0,0" />
                                <CheckBox x:Name="chk_Diag_Tracert" Content="tracert (slow)" VerticalAlignment="Center" Margin="14,0,0,0" />
                            </StackPanel>

                            <!-- Action row -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="btn_Diag_Run"   Content="Run"
                                        Style="{StaticResource PrimaryButton}" Width="90" Height="28" />
                                <Button x:Name="btn_Diag_Stop"  Content="Stop" Width="70" Height="28" Margin="8,0,0,0" />
                                <Button x:Name="btn_Diag_Clear" Content="Clear" Width="70" Height="28" Margin="8,0,0,0" />
                                <Button x:Name="btn_Diag_Save"  Content="Save log..." Width="90" Height="28" Margin="8,0,0,0" />
                                <TextBlock x:Name="lbl_Diag_Status" Text="Idle." VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{StaticResource Text.Muted}" />
                            </StackPanel>

                            <!-- Output console -->
                            <TextBox x:Name="txt_Diag_Output" Grid.Row="3"
                                     AcceptsReturn="True" IsReadOnly="True" TextWrapping="NoWrap"
                                     VerticalContentAlignment="Top"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                     Background="{StaticResource Console.Bg}" Foreground="{StaticResource Console.Fg}" />
                        </Grid>
                    </TabItem>

                    <!-- COM Ports -->
                    <TabItem x:Name="tab_COM" ToolTip="Watch serial/COM devices connect and disconnect">
                        <TabItem.Header>
                            <TextBlock Text="COM Ports" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="120" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Controls -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="btn_COM_Start"   Content="Start monitoring"
                                        Style="{StaticResource PrimaryButton}" Width="130" Height="28" />
                                <Button x:Name="btn_COM_Stop"    Content="Stop" Width="70" Height="28" Margin="8,0,0,0" />
                                <Button x:Name="btn_COM_Refresh" Content="List now" Width="90" Height="28" Margin="8,0,0,0" />
                                <CheckBox x:Name="chk_COM_Beep" Content="Beep on change" VerticalAlignment="Center" Margin="16,0,0,0" />
                                <TextBlock x:Name="lbl_COM_Status" Text="Idle." VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Muted}" />
                            </StackPanel>

                            <!-- Event/port grid -->
                            <DataGrid x:Name="dgr_COM_Results" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time"         Binding="{Binding Time}"         Width="80" />
                                    <DataGridTextColumn Header="Event"        Binding="{Binding Event}"        Width="80" />
                                    <DataGridTextColumn Header="COM"          Binding="{Binding COM}"          Width="70" />
                                    <DataGridTextColumn Header="Name"         Binding="{Binding Name}"         Width="2*" />
                                    <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="*" />
                                    <DataGridTextColumn Header="PNP device ID" Binding="{Binding PNPDeviceID}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="{StaticResource Text.Faint}"
                                       Text="Polls every 2s while monitoring. PRESENT = already connected at start; ADDED/REMOVED = changes since." />
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- ===================== Storage ===================== -->
            <TabItem x:Name="tab_Storage" ToolTip="Storage management tools">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F9F9;" FontFamily="Segoe UI Emoji" Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="Storage" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <TabControl Margin="0" Padding="0" BorderThickness="0">
                    <!-- Storage Cleanup -->
                    <TabItem x:Name="tab_FileCleanup" ToolTip="Find and remove files in a folder">
                        <TabItem.Header>
                            <TextBlock Text="Storage Cleanup" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="120" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Folder row -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label    Grid.Column="0" Content="Folder:" VerticalAlignment="Center" />
                                <ComboBox x:Name="cmb_FC_Path" Grid.Column="1" Margin="6,0" IsEditable="True"
                                          VerticalAlignment="Center" ToolTip="Pick a preset or type/paste a folder path" />
                                <Button   x:Name="btn_FC_Browse" Grid.Column="2" Content="Browse..." Width="90" Height="26" />
                            </Grid>

                            <!-- Filter row -->
                            <Grid Grid.Row="1" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label   Grid.Column="0" Content="Name contains:" VerticalAlignment="Center" />
                                <TextBox x:Name="txt_FC_Filter" Grid.Column="1" Margin="6,0" VerticalAlignment="Center"
                                         ToolTip="Blank = every file. Plain text = name CONTAINS that text. Use * (any chars) or ? (one char) for explicit wildcards." />
                                <CheckBox x:Name="chk_FC_Recurse" Grid.Column="2" Content="Include subfolders"
                                          Margin="12,0,0,0" VerticalAlignment="Center" />
                                <CheckBox x:Name="chk_FC_Recycle" Grid.Column="3" Content="Send to Recycle Bin (recommended)"
                                          Margin="16,0,0,0" VerticalAlignment="Center" IsChecked="True"
                                          ToolTip="Checked: files go to the Recycle Bin (recoverable). Unchecked: permanent delete, no undo.&#10;Note: Windows still permanently deletes files on network shares, removable/USB drives, or any file larger than the Recycle Bin's size limit - even when this is checked." />
                            </Grid>

                            <!-- Matching-rules hint (always visible) -->
                            <TextBlock Grid.Row="2" Margin="0,0,0,6" Foreground="{StaticResource Text.Faint}" TextWrapping="Wrap"
                                       Text="Preview lists files in the folder above whose name matches 'Name contains' (blank = all; plain text = contains; * / ? = wildcards), searching subfolders only when 'Include subfolders' is ticked." />

                            <!-- Action row -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="btn_FC_Preview" Content="Preview"
                                        Style="{StaticResource PrimaryButton}" Width="110" Height="28" />
                                <Button x:Name="btn_FC_Delete"  Content="Delete listed"
                                        Style="{StaticResource DangerButton}" Width="120" Height="28" Margin="8,0,0,0" />
                                <TextBlock x:Name="lbl_FC_Count" Text="No preview yet."
                                           VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{StaticResource Text.Muted}" />
                            </StackPanel>

                            <!-- Results grid -->
                            <DataGrid x:Name="dgr_FC_Results" Grid.Row="4"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column" SelectionMode="Extended">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#"        Binding="{Binding nr}"       Width="40" />
                                    <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="2*" />
                                    <DataGridTextColumn Header="Size (KB)" Binding="{Binding SizeKB}"  Width="90" />
                                    <DataGridTextColumn Header="Modified" Binding="{Binding Modified}" Width="150" />
                                    <DataGridTextColumn Header="Full path" Binding="{Binding FullName}" Width="3*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="5" Margin="0,8,0,0" Foreground="{StaticResource Danger}"
                                       Text="Delete acts on exactly the files listed above. Preview first." />
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- ===================== Software ===================== -->
            <TabItem x:Name="tab_Software" ToolTip="Software management">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4F6;" FontFamily="Segoe UI Emoji" Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="Software" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <TabControl Margin="0" Padding="0" BorderThickness="0">
                    <!-- WinGet Apps -->
                    <TabItem x:Name="tab_WinGet" ToolTip="Install and manage applications via WinGet">
                        <TabItem.Header>
                            <TextBlock Text="WinGet Apps" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="200" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Search and filter row -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <Label   Grid.Column="0" Content="Search:" VerticalAlignment="Center" />
                                <TextBox x:Name="txt_WinGet_Search" Grid.Column="1" Margin="6,0" VerticalAlignment="Center"
                                         ToolTip="Search available WinGet packages (Enter to search)" />
                                <Label   Grid.Column="2" Content="Category:" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <ComboBox x:Name="cmb_WinGet_Category" Grid.Column="3" Margin="6,0" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Action buttons row -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="btn_WinGet_Search" Content="Search" Width="80" Height="28" />
                                <Button x:Name="btn_WinGet_GetInstalled" Content="Get Installed" Width="100" Height="28" Margin="8,0,0,0" />
                                <Button x:Name="btn_WinGet_Clear" Content="Clear" Width="70" Height="28" Margin="8,0,0,0" />
                                <TextBlock x:Name="lbl_WinGet_Status" Text="Ready" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Muted}" />
                            </StackPanel>

                            <!-- App list grid -->
                            <DataGrid x:Name="dgr_WinGet_Apps" Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column" SelectionMode="Extended"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Select" Binding="{Binding Selected}" Width="50" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" IsReadOnly="True" />
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="2*" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="100" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="80" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Install/Uninstall buttons -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="btn_WinGet_Install" Content="Install Selected"
                                        Style="{StaticResource PrimaryButton}" Width="130" Height="28" />
                                <Button x:Name="btn_WinGet_Update" Content="Update All" Width="100" Height="28" Margin="8,0,0,0" />
                                <Button x:Name="btn_WinGet_Uninstall" Content="Uninstall Selected"
                                        Style="{StaticResource DangerButton}" Width="140" Height="28" Margin="8,0,0,0" />
                                <TextBlock Text="Requires WinGet to be installed on the system."
                                           VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Faint}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4" Margin="0,8,0,0" Foreground="{StaticResource Text.Faint}"
                                       Text="WinGet is the Windows Package Manager. Install apps by selecting them and clicking 'Install Selected'. Use 'Get Installed' to see what's already on your system." />
                        </Grid>
                    </TabItem>

                    <!-- Various -->
                    <TabItem x:Name="tab_SoftwareVarious" ToolTip="Various software tools">
                        <TabItem.Header>
                            <TextBlock Text="Various" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <TextBlock Text="Various software tools will be added here." 
                                       Foreground="{StaticResource Text.Muted}" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- ===================== Tools ===================== -->
            <TabItem x:Name="tab_Tools" ToolTip="Power tools and utilities">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4BB;" FontFamily="Segoe UI Emoji" Margin="0,0,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="Tools" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <TabControl Margin="0" Padding="0" BorderThickness="0">
                    <!-- QR Code Generator -->
                    <TabItem x:Name="tab_QRCode" ToolTip="Generate QR codes from text or URLs">
                        <TabItem.Header>
                            <TextBlock Text="QR Code" />
                        </TabItem.Header>
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="200" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Text input row -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Label   Grid.Column="0" Content="Text or URL:" VerticalAlignment="Center" />
                                <TextBox x:Name="txt_QRCode_Text" Grid.Column="1" Margin="6,0" VerticalAlignment="Center"
                                         ToolTip="Enter the text or URL to encode in the QR code" />
                                <Label   Grid.Column="2" Content="Size:" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <ComboBox x:Name="cmb_QRCode_Size" Grid.Column="3" Margin="6,0" VerticalAlignment="Center">
                                    <ComboBoxItem Content="200" Tag="200" />
                                    <ComboBoxItem Content="300" Tag="300" IsSelected="True" />
                                    <ComboBoxItem Content="400" Tag="400" />
                                    <ComboBoxItem Content="500" Tag="500" />
                                </ComboBox>
                            </Grid>

                            <!-- Action buttons row -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                <Button x:Name="btn_QRCode_Generate" Content="Generate QR Code"
                                        Style="{StaticResource PrimaryButton}" Width="140" Height="28" />
                                <Button x:Name="btn_QRCode_Save" Content="Save Image..." Width="110" Height="28" Margin="8,0,0,0" />
                                <Button x:Name="btn_QRCode_Open" Content="Open in Viewer" Width="120" Height="28" Margin="8,0,0,0" />
                                <TextBlock x:Name="lbl_QRCode_Status" Text="Ready" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource Text.Muted}" />
                            </StackPanel>

                            <!-- QR Code display -->
                            <Border Grid.Row="2" Background="{StaticResource Bg.Panel}"
                                    BorderBrush="{StaticResource Border.Hair}" BorderThickness="1"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Padding="20" Margin="0,0,0,12">
                                <Image x:Name="img_QRCode" 
                                       Width="300" Height="300"
                                       Stretch="Uniform"
                                       ToolTip="Generated QR code will appear here" />
                            </Border>

                            <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="{StaticResource Text.Faint}"
                                       Text="Enter any text or URL above and click 'Generate QR Code' to create a scannable QR code. You can then save it as an image or open it in your default image viewer. Scan with any smartphone camera or QR code reader app." />
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

        </TabControl>

        <!-- ============ Log toolbar ============ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="16,10,16,4">
            <TextBlock Text="Activity log" Style="{StaticResource SubHeading}" VerticalAlignment="Center" />
            <CheckBox x:Name="cbx_GetFeedbackMessages" Content="Echo to console"
                      VerticalAlignment="Center" Margin="16,0,0,0" />
        </StackPanel>

        <!-- ============ Visual_Log output ============ -->
        <RichTextBox x:Name="richtxt_Log" Grid.Row="4" Margin="16,0,16,14"
                     VerticalScrollBarVisibility="Auto"
                     IsReadOnly="True" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
    </Grid>
</Window>
